{
  "name": "io-card-issuer",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "npm run start:dev",
    "build": "nest build card-issuer && nest build card-processor",
    "build:issuer": "nest build card-issuer",
    "build:processor": "nest build card-processor",
    "format": "prettier --write \"{apps,libs,scripts,test}/**/*.ts\"",
    "start": "npm run build && concurrently \"npm run start:issuer\" \"npm run start:processor\"",
    "start:dev": "concurrently \"npm run start:issuer:dev\" \"npm run start:processor:dev\"",
    "start:issuer": "nest start card-issuer",
    "start:issuer:dev": "nest start card-issuer --watch",
    "start:issuer:debug": "nest start card-issuer --debug --watch",
    "start:issuer:prod": "node dist/apps/card-issuer/apps/card-issuer/src/main.js",
    "start:processor": "nest start card-processor",
    "start:processor:dev": "nest start card-processor --watch",
    "start:processor:prod": "node dist/apps/card-processor/apps/card-processor/src/main.js",
    "start:prod": "npm run build && concurrently \"npm run start:issuer:prod\" \"npm run start:processor:prod\"",
    "lint": "eslint \"{apps,libs,scripts,test}/**/*.ts\" --fix",
    "migration:create": "node ./node_modules/typeorm/cli.js migration:create libs/shared/src/database/migrations",
    "migration:generate": "node --env-file=.env --require ts-node/register --require tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate libs/shared/src/database/migrations/auto -d libs/shared/src/database/data-source.ts",
    "migration:run": "node --env-file=.env --require ts-node/register --require tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d libs/shared/src/database/data-source.ts",
    "migration:revert": "node --env-file=.env --require ts-node/register --require tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d libs/shared/src/database/data-source.ts",
    "db:setup": "docker compose up -d && npm run migration:run",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/card-issuer/test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "joi": "^18.1.1",
    "kafkajs": "^2.2.4",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@app/shared$": "<rootDir>/libs/shared/src/index.ts",
      "^@app/shared/(.*)$": "<rootDir>/libs/shared/src/$1"
    },
    "collectCoverageFrom": [
      "apps/**/*.ts",
      "libs/**/*.ts"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  }
}
